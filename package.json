{
  "name": "git-workload-report",
  "version": "1.0.4",
  "description": "统计 Git 项目的提交、作者、时间分布和代码改动量",
  "bin": {
    "git-workload-report": "./bin/git-workload-report.sh"
  },
  "files": [
    "bin/git-workload-report.sh",
    "public/local-report",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "bash scripts/build-release.sh",
    "compile": "tsc",
    "dev": "npm run compile && GIT_WORKLOAD_REPORT_KEEP_ALIVE=1 ./bin/git-workload-report.sh",
    "preview": "node dist/index.js",
    "test": "jest"
  },
  "keywords": [
    "git",
    "git-report",
    "commit-statistics",
    "workload",
    "analysis",
    "cli"
  ],
  "author": "gpboyer2",
  "repository": "gpboyer2/git-workload-report",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/yargs": "^17.0.32",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.2"
  },
  "dependencies": {
    "@inquirer/prompts": "^6.0.1",
    "chalk": "^4.1.2",
    "chart.js": "^4.4.9",
    "cli-table3": "^0.6.3",
    "commander": "^11.1.0",
    "holiday-calendar": "^1.3.0",
    "ora": "^5.4.1"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
